# Treat all source as text with auto line endings
* text=auto eol=lf

# C# / Unity scripts
*.cs       text diff=csharp
*.shader   text
*.cginc    text
*.hlsl     text
*.compute  text
*.uss      text
*.uxml     text
*.json     text
*.md       text
*.yml      text
*.yaml     text
*.xml      text

# Force Unity YAML asset files to text so they can be merged
*.unity    text merge=unityyamlmerge eol=lf
*.prefab   text merge=unityyamlmerge eol=lf
*.asset    text merge=unityyamlmerge eol=lf
*.meta     text merge=unityyamlmerge eol=lf
*.mat      text merge=unityyamlmerge eol=lf
*.anim     text merge=unityyamlmerge eol=lf
*.controller text merge=unityyamlmerge eol=lf
*.physicMaterial text merge=unityyamlmerge eol=lf
*.physicsMaterial2D text merge=unityyamlmerge eol=lf
*.terrainlayer text merge=unityyamlmerge eol=lf
*.lighting text merge=unityyamlmerge eol=lf
*.spriteatlas text merge=unityyamlmerge eol=lf
*.spriteatlasv2 text merge=unityyamlmerge eol=lf
*.flare    text merge=unityyamlmerge eol=lf
*.giparams text merge=unityyamlmerge eol=lf
*.guiskin  text merge=unityyamlmerge eol=lf
*.mixer    text merge=unityyamlmerge eol=lf
*.mask     text merge=unityyamlmerge eol=lf
*.brush    text merge=unityyamlmerge eol=lf
*.overrideController text merge=unityyamlmerge eol=lf
*.preset   text merge=unityyamlmerge eol=lf
*.shadergraph text merge=unityyamlmerge eol=lf
*.shadersubgraph text merge=unityyamlmerge eol=lf
*.signal   text merge=unityyamlmerge eol=lf
*.playable text merge=unityyamlmerge eol=lf
*.inputactions text merge=unityyamlmerge eol=lf

